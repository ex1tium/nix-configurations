{
  "nix.enableLanguageServer": true,
  "nix.serverPath": [
    "nix",
    "develop",
    "-c",
    "nixd"
  ],
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [
          "nix",
          "develop",
          "-c",
          "nixfmt"
        ]
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").nixosConfigurations.magos.options"
        }
      }
    }
  },
  "nix.formatterPath": [
    "nixfmt"
  ]
}
